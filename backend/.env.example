# Smart Krishi Backend — Environment Variables
# Copy this to .env and fill in your values

# Server
PORT=5000
NODE_ENV=development

# MongoDB Atlas Connection String
# Get from: https://cloud.mongodb.com → Connect → Drivers
# Format: mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/smartkrishi?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/smartkrishi?retryWrites=true&w=majority

# JWT Secret — use a long random string in production
JWT_SECRET=smart_krishi_super_secret_jwt_key_change_in_production_2024
JWT_EXPIRES_IN=7d

# Frontend URL for CORS
CLIENT_URL=http://localhost:3001
